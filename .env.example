# AegisExam Platform Environment Configurations
# Copy this file to '.env' inside the root directory and update the keys

# LLM Providers Configuration
# If GEMINI_API_KEY is provided, it will be prioritized as the default LLM generator
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
DEFAULT_LLM_PROVIDER=gemini

# Database Settings
# For local SQLite development (default fallback):
DATABASE_URL=sqlite:///./exams.db
# For PostgreSQL (Docker Compose/Neon/Supabase):
# DATABASE_URL=postgresql://postgres:password123@localhost:5432/aegis_exams
# For MySQL:
# DATABASE_URL=mysql+pymysql://root:password123@localhost:3306/aegis_exams

# JWT Authentication Config
SECRET_KEY=aegis_super_secret_jwt_key_change_me_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Next.js Frontend URL (for CORS mapping in development)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
